<section class="auth-layout">
  <div>
    <p class="eyebrow">Photo Portfolio</p>
    <h1>写真から撮影の記録を作る</h1>
    <p class="lead">アップロードした写真のEXIFを読み取り、GPSがあれば地図へ、GPSがなければ撮影日時でセッションに分類します。</p>
  </div>

  <div class="panel auth-panel">
    <h2>ログイン</h2>
    <%= form_with url: login_path, class: 'stack' do |form| %>
      <label>
        メールアドレス
        <%= form.email_field :email, required: true, autocomplete: 'email' %>
      </label>
      <label>
        パスワード
        <%= form.password_field :password, required: true, autocomplete: 'current-password' %>
      </label>
      <%= form.submit 'ログイン', class: 'primary-button' %>
    <% end %>

    <div class="auth-actions">
      <%= button_to 'ゲストログイン', guest_login_path, method: :post, class: 'secondary-button' %>
      <%= link_to 'ユーザー登録', new_user_path %>
    </div>
  </div>
</section>
