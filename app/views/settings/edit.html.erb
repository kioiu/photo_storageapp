<section class="page-header">
  <div>
    <p class="eyebrow">Settings</p>
    <h1>設定</h1>
  </div>
</section>

<section class="form-page">
  <div class="panel form-panel wide">
    <%= form_with model: current_user, url: settings_path, method: :patch, class: 'stack' do |form| %>
      <label>
        フォルダ分け距離
        <%= form.number_field :folder_distance_km, min: 0.1, max: 100, step: 0.1, required: true %>
      </label>
      <p class="form-hint">GPS付き写真が既存フォルダの位置からこの距離以上離れている場合、新しいフォルダを作成します。単位はkmです。</p>
      <%= form.submit '設定を保存', class: 'primary-button' %>
    <% end %>
  </div>
</section>
